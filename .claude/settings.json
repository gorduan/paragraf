{
  "enabledPlugins": {
    "codebase-audit-suite@levnikolaevich-skills-marketplace": true,
    "playwright-skill@playwright-skill": true,
    "ci-cd@devops-skills": true,
    "agile-workflow@levnikolaevich-skills-marketplace": true,
    "project-bootstrap@levnikolaevich-skills-marketplace": true,
    "optimization-suite@levnikolaevich-skills-marketplace": true,
    "security-guidance@claude-plugins-official": true,
    "documentation-pipeline@levnikolaevich-skills-marketplace": true,
    "monitoring-observability@devops-skills": true
  },
  "extraKnownMarketplaces": {
    "levnikolaevich-skills-marketplace": {
      "source": {
        "source": "github",
        "repo": "levnikolaevich/claude-code-skills"
      }
    },
    "playwright-skill": {
      "source": {
        "source": "github",
        "repo": "lackeyjb/playwright-skill"
      }
    },
    "devops-skills": {
      "source": {
        "source": "github",
        "repo": "ahmedasmar/devops-claude-skills"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-check-update.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-context-monitor.js",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-prompt-guard.js",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/gsd-statusline.js"
  }
}
