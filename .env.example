# ── Paragraf – Docker Environment ─────────────────────────────────────────
# Kopieren zu .env und bei Bedarf anpassen.
# Alle Werte koennen auch direkt in docker-compose.yml gesetzt werden.

# Qdrant Konfiguration
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=paragraf

# Embedding-Modell
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=8
EMBEDDING_MAX_LENGTH=512

# Reranker
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_K=5

# RAG Pipeline
RETRIEVAL_TOP_K=20
FINAL_TOP_K=5
SIMILARITY_THRESHOLD=0.35

# Logging
LOG_LEVEL=INFO

# Daten-Verzeichnis (im Container)
DATA_DIR=/data

# Modell-Cache (im Container)
HF_HOME=/models
TORCH_HOME=/models/torch

# Frontend (optional – leer = nginx-Proxy)
# API_BASE_URL=http://localhost:8000
